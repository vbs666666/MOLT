# ============================================================
# MOLT — 环境变量配置
# 复制此文件为 .env 并填入真实值
# ============================================================

# LLM 网关 URL（用于 AI 对话，通过 Vite proxy /claude-api/* 转发）
VITE_LLM_BASE_URL=https://your-llm-gateway.example.com

# LLM API Key
VITE_LLM_API_KEY=your_llm_api_key

# 应用标识（可选）
VITE_APP_ID=your_app_id

# Demo 模式开关（true = 启用 ?demo=1 URL 触发和键盘 d→e→m→o 触发）
VITE_DEMO_MODE=true

# AI 模型选择（传入请求体，代理服务需支持）
# 可选值：claude-haiku-4-5-20251001 | claude-sonnet-4-5 | claude-opus-4-5
VITE_AI_MODEL=claude-haiku-4-5-20251001

# ============================================================
# 如需接入真实 Supabase DB，配置以下变量（否则数据存 localStorage）
# VITE_SUPABASE_URL=https://xxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
# ============================================================
